{
  "version": "1.0",
  "meta": {"strategy_id": "trend_spot_v1", "name": "Trend Spot", "author": "team"},
  "market": {
    "exchange": "okx",
    "trading_mode": "spot",
    "timeframe": "5m",
    "can_short": false,
    "universe": {"mode": "static", "pairs": ["BTC/USDT", "ETH/USDT"], "blacklist": []}
  },
  "data": {
    "startup_candle_count": 300,
    "price_source": "ohlcv",
    "feature_alignment": {"join_on": ["pair", "timeframe", "candle_close_time"], "allow_forward_fill": false, "max_feature_lag_minutes": 60}
  },
  "features": {"external": []},
  "indicators": [
    {"id": "ema_fast", "type": "ema", "source": "close", "timeframe": "5m", "params": {"period": 20}},
    {"id": "ema_slow", "type": "ema", "source": "close", "timeframe": "5m", "params": {"period": 50}},
    {"id": "rsi_14", "type": "rsi", "source": "close", "timeframe": "5m", "params": {"period": 14}}
  ],
  "signals": {
    "enter_long": {"logic": "all", "rules": [{"left": "ema_fast", "op": ">", "right": "ema_slow"}, {"left": "rsi_14", "op": ">", "right": 55}], "tag": "trend_long"},
    "exit_long": {"logic": "any", "rules": [{"left": "rsi_14", "op": ">", "right": 72}]}
  },
  "risk": {"max_open_trades": 3, "stake": {"mode": "fixed_fraction", "value": 0.02}, "stoploss": {"mode": "fixed", "value": -0.1}, "take_profit": {"mode": "roi_schedule", "steps": [{"minutes": 0, "roi": 0.03}] }},
  "protections": [{"method": "CooldownPeriod", "stop_duration_candles": 2}],
  "optimization": {"enabled": false},
  "validation": {"require_lookahead_analysis": true, "require_recursive_analysis": true, "min_trades": 50},
  "reporting": {"export_trades": true, "export_signals": true, "save_metrics_json": true, "save_compiled_strategy": true, "save_manifest": true}
}
