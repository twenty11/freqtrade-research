{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "meta", "market", "data", "features", "indicators", "signals", "risk", "validation", "reporting"],
  "properties": {
    "version": {"type": "string"},
    "meta": {"type": "object"},
    "market": {
      "type": "object",
      "required": ["exchange", "trading_mode", "timeframe", "can_short", "universe"],
      "properties": {
        "exchange": {"const": "okx"},
        "trading_mode": {"enum": ["spot", "futures"]},
        "can_short": {"type": "boolean"},
        "timeframe": {"type": "string"}
      }
    },
    "indicators": {"type": "array"},
    "protections": {"type": "array"}
  }
}
